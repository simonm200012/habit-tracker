# ============================================================
# Required
# ============================================================
# Supabase — create a project at https://supabase.com and copy these from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ============================================================
# Optional — base URL (used for share links and email/push deep-links)
# ============================================================
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app

# ============================================================
# Optional — Cron jobs (Tier 7)
# ============================================================
# Vercel auto-supplies this when you add the project; set it locally too
# if you want to call /api/cron/* by hand.
CRON_SECRET=

# Service-role key (from Supabase → API → service_role).
# REQUIRED to actually send cron notifications — bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# Optional — Web Push (Tier 7)
# Generate VAPID keys once:  npx web-push generate-vapid-keys
# ============================================================
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ============================================================
# Optional — Email digests (Tier 7)
# Sign up at https://resend.com (free tier), verify a sending domain.
# ============================================================
RESEND_API_KEY=
RESEND_FROM="habit-tracker <digest@yourdomain.com>"
